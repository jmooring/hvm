# User cache and config dirs (we use os.UserCacheDir and os.UserConfigDir)
[darwin] mkdir "$HOME/Library/Caches"
[darwin] mkdir "$HOME/Library/Application Support"

# Test
stdin input.txt
! exec hvm status
stderr 'Error: unable to get \.hvm \(v\d+\.\d+\.\d+/\w+\): .+: run "hvm use" to select a version, or "hvm disable" to remove the file\n'
-- input.txt --
y
-- .hvm --
v9.999.9/extended
